<Window x:Class="SpeedEmulator.Views.FlowGenerationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SpeedEmulator.Controls"
        Title="{Binding WindowTitle, Mode=OneWay, FallbackValue=流水自动生成页面}"
        Width="1440"
        Height="820"
        MinWidth="1180"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="#E9E9E9"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="TopLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="TopTextBoxStyle" TargetType="TextBox">
            <Setter Property="Width" Value="120" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#D2D5D7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#6AA0D8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBorder" Property="Opacity" Value="0.58" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopDateStyle" TargetType="controls:FormattedDatePicker">
            <Setter Property="Width" Value="160" />
            <Setter Property="Height" Value="36" />
            <Setter Property="BorderBrush" Value="#D2D5D7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="100" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CDD2D5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F7F7F7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EDEDED" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CDD2D5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F7F7F7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EDEDED" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GeneratorTabStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="#E9E9E9" />
            <Setter Property="BorderBrush" Value="#D8D8D8" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="RuleGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="#D7D7D7" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="RuleGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderBrush" Value="#D8D8D8" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0057D9" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RuleGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#C5DBF2" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0057D9" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Bottom"
                Height="28"
                Padding="8,4"
                Background="#E9E9E9">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#34464B"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <TextBlock HorizontalAlignment="Right"
                           Foreground="#34464B"
                           FontSize="12"
                           VerticalAlignment="Center">
                    <Run Text="当前用户：" />
                    <Run Text="{Binding BankUserName, Mode=OneWay}" />
                </TextBlock>
            </Grid>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="260" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="20,22,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="560" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="开始日期" Style="{StaticResource TopLabelStyle}" />
                    <controls:FormattedDatePicker SelectedDate="{Binding Config.StartTime, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayFormat="yyyy年MM月dd日"
                                                  Style="{StaticResource TopDateStyle}" />

                    <TextBlock Text="结束日期"
                               Margin="0,10,0,4"
                               Style="{StaticResource TopLabelStyle}" />
                    <controls:FormattedDatePicker SelectedDate="{Binding Config.EndTime, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayFormat="yyyy年MM月dd日"
                                                  Style="{StaticResource TopDateStyle}" />

                    <TextBlock Text="期初余额"
                               Margin="0,10,0,4"
                               Style="{StaticResource TopLabelStyle}" />
                    <TextBox Text="{Binding Config.OpeningBalance, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                             Style="{StaticResource TopTextBoxStyle}"
                             Width="160" />
                </StackPanel>

                <TabControl Grid.Column="1"
                            SelectedIndex="{Binding Config.SelectIndex}"
                            ItemContainerStyle="{StaticResource GeneratorTabStyle}"
                            Background="#E9E9E9"
                            BorderThickness="0">
                    <TabItem Header="按总进账金额方式分配金额">
                        <Grid Margin="6,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="128" />
                                <ColumnDefinition Width="94" />
                                <ColumnDefinition Width="134" />
                                <ColumnDefinition Width="134" />
                                <ColumnDefinition Width="134" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="58" />
                                <RowDefinition Height="58" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="总进账金额" Style="{StaticResource TopLabelStyle}" />
                                <TextBox Text="{Binding Config.AllInMoney, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         Style="{StaticResource TopTextBoxStyle}" />
                            </StackPanel>

                            <Button Grid.RowSpan="2"
                                    Grid.Column="1"
                                    Content="计算"
                                    Width="70"
                                    Height="30"
                                    Margin="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Command="{Binding ComputeCommand}"
                                    Style="{StaticResource SmallButtonStyle}" />

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="月收入最小金额" Style="{StaticResource TopLabelStyle}" />
                                <TextBox Text="{Binding Config.MinInMoneyMonth1, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         Style="{StaticResource TopTextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="月支出最小金额" Style="{StaticResource TopLabelStyle}" />
                                <TextBox Text="{Binding Config.MinOutMoneyMonth1, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         Style="{StaticResource TopTextBoxStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1">
                                <TextBlock Text="最后卡上余额" Style="{StaticResource TopLabelStyle}" />
                                <TextBox Text="{Binding Config.LastMoney, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         Style="{StaticResource TopTextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1"
                                        Grid.Column="2">
                                <TextBlock Text="月收入最大金额" Style="{StaticResource TopLabelStyle}" />
                                <TextBox Text="{Binding Config.MaxInMoneyMonth1, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         Style="{StaticResource TopTextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1"
                                        Grid.Column="3">
                                <TextBlock Text="月支出最大金额" Style="{StaticResource TopLabelStyle}" />
                                <TextBox Text="{Binding Config.MaxOutMoneyMonth1, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         Style="{StaticResource TopTextBoxStyle}" />
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="按月进账金额方式分配金额">
                        <Grid Margin="6,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="134" />
                                <ColumnDefinition Width="134" />
                                <ColumnDefinition Width="134" />
                                <ColumnDefinition Width="134" />
                                <ColumnDefinition Width="134" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="58" />
                                <RowDefinition Height="58" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="月收入最小金额" Style="{StaticResource TopLabelStyle}" />
                                <TextBox Text="{Binding Config.MinInMoneyMonth2, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         Style="{StaticResource TopTextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="月支出最小金额" Style="{StaticResource TopLabelStyle}" />
                                <TextBox Text="{Binding Config.MinOutMoneyMonth2, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         Style="{StaticResource TopTextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1"
                                        Grid.Column="0">
                                <TextBlock Text="月收入最大金额" Style="{StaticResource TopLabelStyle}" />
                                <TextBox Text="{Binding Config.MaxInMoneyMonth2, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         Style="{StaticResource TopTextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1"
                                        Grid.Column="1">
                                <TextBlock Text="月支出最大金额" Style="{StaticResource TopLabelStyle}" />
                                <TextBox Text="{Binding Config.MaxOutMoneyMonth2, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         Style="{StaticResource TopTextBoxStyle}" />
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="按月明细分配">
                        <Grid Margin="6,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="146" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="58" />
                                <RowDefinition Height="58" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="0">
                                <TextBlock Text="总进账金额"
                                           Style="{StaticResource TopLabelStyle}" />
                                <TextBox Text="{Binding Config.AllInMoney, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         Style="{StaticResource TopTextBoxStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Grid.Column="0">
                                <TextBlock Text="总出账金额"
                                           Style="{StaticResource TopLabelStyle}" />
                                <TextBox Text="{Binding Config.AllOutMoney, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         Style="{StaticResource TopTextBoxStyle}" />
                            </StackPanel>

                            <Button Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="1"
                                    Content="月份明细设置"
                                    Command="{Binding OpenMonthDetailSettingsCommand}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="0"
                                    Style="{StaticResource SmallButtonStyle}" />
                        </Grid>
                    </TabItem>
                </TabControl>

                <StackPanel Grid.Column="2"
                            Margin="0,52,0,0">
                    <Button Content="保存配置"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource SmallButtonStyle}" />
                    <Button Content="开始生成"
                            Margin="0,60,10,0"
                            Command="{Binding StartGenerateCommand}"
                            Style="{StaticResource SmallButtonStyle}" />
                </StackPanel>

                <Grid Grid.Column="3"
                      Margin="34,8,0,0"
                      HorizontalAlignment="Left">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="44" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="随机分子"
                                   VerticalAlignment="Center"
                                   Foreground="#777777"
                                   FontSize="13" />
                        <TextBlock Text="i"
                                   Width="18"
                                   Height="18"
                                   Margin="20,0,0,0"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   Background="#2568C5"
                                   FontWeight="Bold" />
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <TextBlock Text="状态:"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Foreground="#777777" />
                        <TextBox Text="{Binding ExcelStatus, Mode=OneWay}"
                                 Width="80"
                                 Height="34"
                                 IsReadOnly="True"
                                 Foreground="#999999"
                                 Background="#F3F3F3"
                                 BorderBrush="#D2D5D7"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0" />
                        <Button Content="读取Excel文件"
                                Margin="20,0,10,0"
                                Command="{Binding ReadExcelCommand}"
                                Style="{StaticResource SmallButtonStyle}" />
                        <Button Content="清空"
                                Command="{Binding ClearExcelCommand}"
                                Style="{StaticResource SmallButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <TabControl x:Name="RulesTab"
                            SelectedIndex="{Binding SelectedTabIndex}"
                            Margin="0,0,0,0"
                            ItemContainerStyle="{StaticResource GeneratorTabStyle}"
                            Background="#E9E9E9"
                            BorderThickness="0">
                    <TabItem Header="参照明细">
                        <DataGrid x:Name="ReferenceGrid"
                                  ItemsSource="{Binding References}"
                                  SelectedItem="{Binding SelectedReference, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="False"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  GridLinesVisibility="None"
                                  Background="#E9E9E9"
                                  RowBackground="White"
                                  AlternatingRowBackground="#C5DBF2"
                                  AlternationCount="2"
                                  BorderThickness="0"
                                  ColumnHeaderStyle="{StaticResource RuleGridHeaderStyle}"
                                  CellStyle="{StaticResource RuleGridCellStyle}"
                                  RowStyle="{StaticResource RuleGridRowStyle}"
                                  ColumnHeaderHeight="36"
                                  RowHeight="32"
                                  FontSize="14"
                                  SnapsToDevicePixels="True"
                                  PreviewMouseLeftButtonDown="RulesGrid_PreviewMouseLeftButtonDown"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto" />
                    </TabItem>

                    <TabItem Header="固定日期增加项目">
                        <DataGrid x:Name="ConstGrid"
                                  ItemsSource="{Binding ConstItems}"
                                  SelectedItem="{Binding SelectedConst, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="False"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  GridLinesVisibility="None"
                                  Background="#E9E9E9"
                                  RowBackground="White"
                                  AlternatingRowBackground="#C5DBF2"
                                  AlternationCount="2"
                                  BorderThickness="0"
                                  ColumnHeaderStyle="{StaticResource RuleGridHeaderStyle}"
                                  CellStyle="{StaticResource RuleGridCellStyle}"
                                  RowStyle="{StaticResource RuleGridRowStyle}"
                                  ColumnHeaderHeight="36"
                                  RowHeight="32"
                                  FontSize="14"
                                  SnapsToDevicePixels="True"
                                  PreviewMouseLeftButtonDown="RulesGrid_PreviewMouseLeftButtonDown"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto" />
                    </TabItem>
                </TabControl>

                <StackPanel Grid.Column="1"
                            Margin="10,42,10,0"
                            VerticalAlignment="Top">
                    <Button Content="新增" Command="{Binding NewCommand}" Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="删除" Command="{Binding DeleteCommand}" Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="保存" Command="{Binding SaveCommand}" Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="设置利息" Command="{Binding SetInterestCommand}" Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="设置字段" Command="{Binding SetColumnsCommand}" Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="导入EXCEL" Command="{Binding ImportExcelCommand}" Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="导出EXCEL" Command="{Binding ExportExcelCommand}" Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="返回" Command="{Binding BackCommand}" Style="{StaticResource ActionButtonStyle}" />
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
