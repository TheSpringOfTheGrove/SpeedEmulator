<Window x:Class="SpeedEmulator.Views.BankUserColumnSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle, FallbackValue=字段设置}"
        Width="520"
        Height="640"
        MinWidth="480"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F5F5">
    <Window.Resources>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="82" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CDD2D5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SettingsGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="#D5D5D5" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SettingsGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Margin="14">
        <TextBlock DockPanel.Dock="Top"
                   Text="字段设置"
                   FontSize="15"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10" />

        <Border DockPanel.Dock="Bottom"
                Padding="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#52646A"
                           FontSize="12"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="保存"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource DialogButtonStyle}" />
                    <Button Content="取消"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource DialogButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid ItemsSource="{Binding Columns}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  GridLinesVisibility="None"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#F8F8F8"
                  AlternationCount="2"
                  BorderBrush="#D8D8D8"
                  BorderThickness="1"
                  ColumnHeaderStyle="{StaticResource SettingsGridHeaderStyle}"
                  CellStyle="{StaticResource SettingsGridCellStyle}"
                  RowHeight="38"
                  FontSize="14"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="字段名"
                                    Binding="{Binding Name}"
                                    Width="*"
                                    MinWidth="170"
                                    IsReadOnly="True" />
                <DataGridTextColumn Header="宽度"
                                    Binding="{Binding Width, UpdateSourceTrigger=LostFocus}"
                                    Width="78"
                                    MinWidth="70" />
                <DataGridTextColumn Header="顺序"
                                    Binding="{Binding Order, UpdateSourceTrigger=LostFocus}"
                                    Width="78"
                                    MinWidth="70" />
                <DataGridCheckBoxColumn Header="是否显示"
                                        Binding="{Binding Show, UpdateSourceTrigger=PropertyChanged}"
                                        Width="86"
                                        MinWidth="82" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
