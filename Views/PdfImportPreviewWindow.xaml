<Window x:Class="SpeedEmulator.Views.PdfImportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle, FallbackValue=PDF导入预览}"
        Width="920"
        Height="680"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F5F5">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="88" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CDD2D5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PreviewGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="#D5D5D5" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PreviewGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Margin="14">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock Text="PDF导入预览"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding Summary}"
                       Foreground="#34434A"
                       FontSize="13"
                       Margin="0,8,0,0" />
            <TextBlock Text="{Binding SourceFile}"
                       Foreground="#68777E"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,3,0,0" />
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Padding="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#52646A"
                           FontSize="12"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="导入"
                            Command="{Binding ConfirmCommand}"
                            IsEnabled="{Binding CanImport}"
                            Style="{StaticResource DialogButtonStyle}" />
                    <Button Content="取消"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource DialogButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Background="Transparent">
            <TabItem Header="用户信息"
                     Visibility="{Binding HasUsers, Converter={StaticResource BoolToVisibilityConverter}}">
                <DataGrid ItemsSource="{Binding Users}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0"
                          GridLinesVisibility="None"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#F8F8F8"
                          AlternationCount="2"
                          BorderBrush="#D8D8D8"
                          BorderThickness="1"
                          ColumnHeaderStyle="{StaticResource PreviewGridHeaderStyle}"
                          CellStyle="{StaticResource PreviewGridCellStyle}"
                          RowHeight="34"
                          FontSize="13"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="编号" Binding="{Binding UserCode}" Width="110" />
                        <DataGridTextColumn Header="户名/姓名" Binding="{Binding AccountName}" Width="120" />
                        <DataGridTextColumn Header="账号" Binding="{Binding AccountNo}" Width="160" />
                        <DataGridTextColumn Header="卡号" Binding="{Binding CardNo}" Width="160" />
                        <DataGridTextColumn Header="证件号" Binding="{Binding IdNumber}" Width="160" />
                        <DataGridTextColumn Header="开始日期" Binding="{Binding StartDate, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="150" />
                        <DataGridTextColumn Header="结束日期" Binding="{Binding EndDate, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="150" />
                        <DataGridTextColumn Header="期初余额" Binding="{Binding OpeningBalance, StringFormat=0.00}" Width="100" />
                        <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="160" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="流水明细"
                     Visibility="{Binding HasFlowRecords, Converter={StaticResource BoolToVisibilityConverter}}">
                <DataGrid ItemsSource="{Binding FlowRecords}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0"
                          GridLinesVisibility="None"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#F8F8F8"
                          AlternationCount="2"
                          BorderBrush="#D8D8D8"
                          BorderThickness="1"
                          ColumnHeaderStyle="{StaticResource PreviewGridHeaderStyle}"
                          CellStyle="{StaticResource PreviewGridCellStyle}"
                          RowHeight="34"
                          FontSize="13"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Index}" Width="54" />
                        <DataGridTextColumn Header="交易时间" Binding="{Binding AccountTime, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="150" />
                        <DataGridTextColumn Header="交易金额" Binding="{Binding TradeMoney, StringFormat=0.00}" Width="100" />
                        <DataGridTextColumn Header="余额" Binding="{Binding Balance, StringFormat=0.00}" Width="100" />
                        <DataGridTextColumn Header="收支" Binding="{Binding IncomeAttribute}" Width="72" />
                        <DataGridTextColumn Header="摘要" Binding="{Binding ProductBrief}" Width="130" />
                        <DataGridTextColumn Header="对方户名" Binding="{Binding OppositeUsername}" Width="130" />
                        <DataGridTextColumn Header="对方账号" Binding="{Binding OppositeAccount}" Width="150" />
                        <DataGridTextColumn Header="附言/备注" Binding="{Binding Remark}" Width="160" />
                        <DataGridTextColumn Header="交易渠道" Binding="{Binding TradeChannel}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="问题列表"
                     Visibility="{Binding HasIssues, Converter={StaticResource BoolToVisibilityConverter}}">
                <DataGrid ItemsSource="{Binding Issues}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0"
                          GridLinesVisibility="None"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#F8F8F8"
                          AlternationCount="2"
                          BorderBrush="#D8D8D8"
                          BorderThickness="1"
                          ColumnHeaderStyle="{StaticResource PreviewGridHeaderStyle}"
                          CellStyle="{StaticResource PreviewGridCellStyle}"
                          RowHeight="34"
                          FontSize="13"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="级别" Binding="{Binding Severity}" Width="80" />
                        <DataGridTextColumn Header="页" Binding="{Binding PageNumber}" Width="54" />
                        <DataGridTextColumn Header="行" Binding="{Binding LineNumber}" Width="54" />
                        <DataGridTextColumn Header="说明" Binding="{Binding Message}" Width="*" MinWidth="280" />
                        <DataGridTextColumn Header="原文" Binding="{Binding RawText}" Width="260" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="原文片段">
                <TextBox Text="{Binding RawTextPreview, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="White"
                         BorderBrush="#D8D8D8"
                         BorderThickness="1"
                         Padding="10" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
