<Window x:Class="SpeedEmulator.Views.MonthDetailSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SpeedEmulator.Controls"
        Title="按月明细设置"
        Width="590"
        Height="430"
        MinWidth="560"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FFFFFF">
    <Window.Resources>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D7D7D7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MonthHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="#D7D7D7" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MonthCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="BorderBrush" Value="#D8D8D8" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#BFD6F0" />
                    <Setter Property="Foreground" Value="#111111" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MonthRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#C5DBF2" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#BFD6F0" />
                    <Setter Property="Foreground" Value="#111111" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20,28,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="118" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="42" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="功能区"
                           Style="{StaticResource SectionTitleStyle}" />
                <Border Grid.Column="1"
                        Height="1"
                        Margin="12,0,70,0"
                        Background="#E5E5E5"
                        VerticalAlignment="Center" />
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Content="新增"
                        Command="{Binding AddMonthDetailCommand}"
                        Style="{StaticResource DialogButtonStyle}" />
                <Button Content="清空"
                        Command="{Binding ClearMonthDetailsCommand}"
                        Style="{StaticResource DialogButtonStyle}" />
                <Button Content="开始生成"
                        Command="{Binding StartGenerateCommand}"
                        Style="{StaticResource DialogButtonStyle}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="月份设置"
                           Style="{StaticResource SectionTitleStyle}" />
                <Border Grid.Column="1"
                        Height="1"
                        Margin="12,0,64,0"
                        Background="#E5E5E5"
                        VerticalAlignment="Center" />
            </Grid>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Config.MonthGenData}"
                      SelectedItem="{Binding SelectedMonthDetail, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      GridLinesVisibility="None"
                      Background="#FFFFFF"
                      RowBackground="White"
                      AlternatingRowBackground="#C5DBF2"
                      AlternationCount="1000000"
                      BorderThickness="0"
                      ColumnHeaderStyle="{StaticResource MonthHeaderStyle}"
                      CellStyle="{StaticResource MonthCellStyle}"
                      RowStyle="{StaticResource MonthRowStyle}"
                      ColumnHeaderHeight="36"
                      RowHeight="36"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="开始月份" Width="190">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <controls:FormattedDatePicker SelectedDate="{Binding StartTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Height="30"
                                                              BorderThickness="0"
                                                              Background="Transparent" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="结束月份" Width="190">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <controls:FormattedDatePicker SelectedDate="{Binding EndTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Height="30"
                                                              BorderThickness="0"
                                                              Background="Transparent" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="入账金额"
                                        Binding="{Binding InMoney, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=N2}"
                                        Width="100" />
                    <DataGridTextColumn Header="出账金额"
                                        Binding="{Binding OutMoney, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=N2}"
                                        Width="100" />
                    <DataGridTemplateColumn Header="" Width="72">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="删除"
                                        Height="26"
                                        MinWidth="56"
                                        Padding="8,0"
                                        Margin="0"
                                        Command="{Binding DataContext.DeleteMonthDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource DialogButtonStyle}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
