<Window x:Class="SpeedEmulator.Views.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="{Binding WindowTitle}"
        Width="1280"
        Height="760"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        Background="#E9E9E9">
    <Window.Resources>
        <Style x:Key="PrintButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#C8D1D5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TemplateGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowHeight" Value="32" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#E9E9E9" />
            <Setter Property="RowBackground" Value="#E9E9E9" />
            <Setter Property="AlternatingRowBackground" Value="#E9E9E9" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="46" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="..."
                   Margin="14,10,14,0"
                   VerticalAlignment="Center"
                   FontSize="16" />

        <Grid Grid.Row="1" Margin="14,8,14,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="TemplateGrid"
                      ItemsSource="{Binding Templates}"
                      SelectedItem="{Binding SelectedTemplate}"
                      Style="{StaticResource TemplateGridStyle}"
                      PreviewMouseRightButtonDown="TemplateGrid_PreviewMouseRightButtonDown">
                <DataGrid.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="新增模板" Command="{Binding NewTemplateCommand}" />
                        <MenuItem Header="复制模板" Command="{Binding CopyTemplateCommand}" />
                        <MenuItem Header="设置模板" Command="{Binding SettingTemplateCommand}" />
                        <MenuItem Header="保存模板" Command="{Binding SaveTemplateCommand}" />
                        <MenuItem Header="导入模板" Command="{Binding ImportTemplateCommand}" />
                        <MenuItem Header="导出模板" Command="{Binding ExportTemplateCommand}" />
                        <MenuItem Header="删除模板" Command="{Binding DeleteTemplateCommand}" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="系统" Binding="{Binding SystemText}" Width="52" />
                    <DataGridTextColumn Header="模板名字" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="页" Binding="{Binding PageRows}" Width="42" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="112" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="2"
                    Background="#DADADA"
                    BorderBrush="#D1D1D1"
                    BorderThickness="1">
                <Grid>
                    <wv2:WebView2 x:Name="PreviewWebView"
                                  DefaultBackgroundColor="#DADADA" />
                    <TextBlock x:Name="PreviewFallback"
                               Text="请选择模板后点击生成预览"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="15"
                               Foreground="#404040" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="14,8,14,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       Foreground="#4A6269" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Content="生成预览" Command="{Binding GeneratePreviewCommand}" Style="{StaticResource PrintButtonStyle}" />
                <Button Content="打开PDF" Command="{Binding OpenPdfCommand}" Style="{StaticResource PrintButtonStyle}" />
                <Button Content="打印" Command="{Binding PrintPdfCommand}" Style="{StaticResource PrintButtonStyle}" />
                <Button Content="导出PDF" Command="{Binding ExportPdfCommand}" Style="{StaticResource PrintButtonStyle}" />
                <Button Content="返回" Command="{Binding BackCommand}" Style="{StaticResource PrintButtonStyle}" Margin="0" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
