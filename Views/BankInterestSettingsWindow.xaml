<Window x:Class="SpeedEmulator.Views.BankInterestSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle, FallbackValue=利息设置}"
        Width="430"
        Height="620"
        MinWidth="390"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <Window.Resources>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="82" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CDD2D5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="86" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ValueTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="BorderBrush" Value="#CDD2D5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Margin="14">
        <Border DockPanel.Dock="Bottom"
                Padding="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#52646A"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="保存"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource DialogButtonStyle}" />
                    <Button Content="删除"
                            Command="{Binding DeleteCommand}"
                            Style="{StaticResource DialogButtonStyle}" />
                    <Button Content="取消"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource DialogButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="6,8,16,6">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="106" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="日期" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Grid.Column="1"
                             Text="{Binding Setting.SettlementDay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ValueTextBoxStyle}" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="106" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="月份" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Grid.Column="1"
                             Text="{Binding Setting.Months, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ValueTextBoxStyle}" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="106" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="开始时间" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Grid.Column="1"
                             Text="{Binding Setting.StartTime, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ValueTextBoxStyle}" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="106" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="结束时间" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Grid.Column="1"
                             Text="{Binding Setting.EndTime, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ValueTextBoxStyle}" />
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="106" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="利率(%)" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Grid.Column="1"
                             Text="{Binding Setting.RatePercent, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ValueTextBoxStyle}" />
                </Grid>

                <Border Height="1"
                        Background="#DCDCDC"
                        Margin="0,0,0,12" />

                <ItemsControl ItemsSource="{Binding Fields}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="106" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ValueTextBoxStyle}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
