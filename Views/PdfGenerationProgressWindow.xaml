<Window x:Class="SpeedEmulator.Views.PdfGenerationProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="正在生成pdf中..."
        Width="420"
        Height="190"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="#4792EA">
    <Grid Background="#4792EA">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock Text="正在生成pdf中..."
                       HorizontalAlignment="Center"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <ProgressBar Width="220"
                         Height="18"
                         Margin="0,42,0,0"
                         IsIndeterminate="True"
                         Minimum="0"
                         Maximum="100" />
        </StackPanel>
    </Grid>
</Window>
