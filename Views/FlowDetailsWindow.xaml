<Window x:Class="SpeedEmulator.Views.FlowDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle, Mode=OneWay, FallbackValue=流水页}"
        Width="1120"
        Height="820"
        MinWidth="1020"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#E9E9E9"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="FlowSideButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80" />
            <Setter Property="Height" Value="29" />
            <Setter Property="Margin" Value="0,0,0,9" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CDD2D5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F7F9FA" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#BFC8CE" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E9EEF2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#F3F3F3" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#DDDDDD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#B8B8B8" />
                    <Setter Property="Opacity" Value="0.75" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FlowFooterButtonStyle" TargetType="Button" BasedOn="{StaticResource FlowSideButtonStyle}">
            <Setter Property="Width" Value="80" />
            <Setter Property="Margin" Value="12,0,0,0" />
        </Style>

        <Style x:Key="FlowGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="#EDEDED" />
            <Setter Property="BorderBrush" Value="#D4D4D4" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="FlowGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="BorderBrush" Value="#D8D8D8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource AncestorType=DataGridRow}}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0B17FF" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FlowGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#C9DFF5" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0B17FF" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FooterTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="BorderBrush" Value="#D2D5D7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#9FB7CB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Bottom"
                Height="42"
                Padding="20,6,20,6"
                Background="#E9E9E9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="总笔数:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Text="{Binding TotalCount, Mode=OneWay}"
                             Width="80"
                             IsReadOnly="True"
                             Style="{StaticResource FooterTextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="收入合计:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Text="{Binding AllIncome, Mode=OneWay, StringFormat=F2}"
                             Width="94"
                             IsReadOnly="True"
                             Style="{StaticResource FooterTextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="支出合计:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Text="{Binding AllOut, Mode=OneWay, StringFormat=F2}"
                             Width="104"
                             IsReadOnly="True"
                             Style="{StaticResource FooterTextBoxStyle}" />
                </StackPanel>

                <Button Grid.Column="3"
                        Content="计算"
                        Command="{Binding ReComputeBalanceCommand}"
                        Style="{StaticResource FlowFooterButtonStyle}" />
                <Button Grid.Column="4"
                        Content="时间排序"
                        Command="{Binding ReSortByDateCommand}"
                        Style="{StaticResource FlowFooterButtonStyle}" />
                <CheckBox Grid.Column="5"
                          Content="自动计算利息"
                          IsChecked="{Binding AutoCalculateInterest}"
                          VerticalAlignment="Center"
                          Margin="12,0,0,0" />

                <TextBlock Grid.Column="6"
                           Text="{Binding StatusMessage}"
                           Foreground="#34464B"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           FontSize="12" />
            </Grid>
        </Border>

        <Grid Margin="20,24,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="108" />
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="FlowGrid"
                      ItemsSource="{Binding Records}"
                      SelectedItem="{Binding SelectedRecord, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      GridLinesVisibility="None"
                      Background="#E9E9E9"
                      RowBackground="White"
                      AlternatingRowBackground="#C9DFF5"
                      AlternationCount="2"
                      BorderThickness="0"
                      ColumnHeaderStyle="{StaticResource FlowGridHeaderStyle}"
                      CellStyle="{StaticResource FlowGridCellStyle}"
                      RowStyle="{StaticResource FlowGridRowStyle}"
                      ColumnHeaderHeight="32"
                      RowHeight="32"
                      FontSize="14"
                      SnapsToDevicePixels="True"
                      PreviewMouseLeftButtonDown="FlowGrid_PreviewMouseLeftButtonDown"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto" />

            <StackPanel Grid.Column="2" VerticalAlignment="Top">
                <TextBlock Text="期初余额:"
                           HorizontalAlignment="Center"
                           Margin="0,32,0,6" />
                <TextBox Text="{Binding OpeningBalance, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                         Width="80"
                         HorizontalAlignment="Center"
                         Style="{StaticResource FooterTextBoxStyle}" />

                <Button Content="复制" Command="{Binding CopyRecordCommand}" Margin="0,12,0,10" Style="{StaticResource FlowSideButtonStyle}" />
                <Button Content="插入空行" Command="{Binding InsertBlankRecordCommand}" Style="{StaticResource FlowSideButtonStyle}" />
                <Button Content="删除" Command="{Binding DeleteRecordCommand}" Style="{StaticResource FlowSideButtonStyle}" />
                <Button Content="上移" Command="{Binding MoveUpRecordCommand}" Style="{StaticResource FlowSideButtonStyle}" />
                <Button Content="下移" Command="{Binding MoveDownRecordCommand}" Style="{StaticResource FlowSideButtonStyle}" />
                <Button Content="时间排序" Command="{Binding ReSortByDateCommand}" Style="{StaticResource FlowSideButtonStyle}" />
                <Button Content="保存全部" Command="{Binding SaveAllRecordCommand}" Style="{StaticResource FlowSideButtonStyle}" />
                <Button Content="打印" Command="{Binding PrintRecordCommand}" Style="{StaticResource FlowSideButtonStyle}" />
                <Button Content="导入xlsx" Command="{Binding ImportRecordCommand}" Style="{StaticResource FlowSideButtonStyle}" />
                <Button Content="导出xlsx" Command="{Binding ExportRecordCommand}" Style="{StaticResource FlowSideButtonStyle}" />
                <Button Content="开启筛选" Command="{Binding OpenFilterCommand}" Style="{StaticResource FlowSideButtonStyle}" />
                <Button Content="设置字段" Command="{Binding SetColumnFieldCommand}" Style="{StaticResource FlowSideButtonStyle}" />
                <Button Content="转换公式" Command="{Binding ConvertFormulaCommand}" IsEnabled="False" Style="{StaticResource FlowSideButtonStyle}" />
                <Button Content="查看统计" Command="{Binding ShowStaticCommand}" Style="{StaticResource FlowSideButtonStyle}" />
                <Button Content="返回" Command="{Binding CloseCommand}" Style="{StaticResource FlowSideButtonStyle}" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
