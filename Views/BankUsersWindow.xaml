<Window x:Class="SpeedEmulator.Views.BankUsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SpeedEmulator.Controls"
        Title="{Binding WindowTitle, Mode=OneWay, FallbackValue=流水主页界面}"
        Width="1280"
        Height="760"
        MinWidth="1100"
        MinHeight="660"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="#E9E9E9"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="SideButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="118" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CDD2D5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="MiniButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CDD2D5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="66" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="BorderBrush" Value="#C5CBCD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="EditorDateStyle" TargetType="controls:FormattedDatePicker">
            <Setter Property="Height" Value="28" />
            <Setter Property="BorderBrush" Value="#C5CBCD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="FormRowStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="UserGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="#F6F6F6" />
            <Setter Property="BorderBrush" Value="#D2D2D2" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#111111" />
        </Style>

        <Style x:Key="UserGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderBrush" Value="#D8D8D8" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1F65D6" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="#D8D8D8" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="UserGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F7F7F7" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1F65D6" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Bottom"
                Background="#E9E9E9"
                Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#34464B"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Foreground="#34464B"
                           FontSize="12"
                           VerticalAlignment="Center">
                    <Run Text="列表记录 " />
                    <Run Text="{Binding Users.Count, Mode=OneWay}" />
                    <Run Text=" 条" />
                </TextBlock>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="286" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="136" />
            </Grid.ColumnDefinitions>

            <Border Background="#E9E9E9"
                    Padding="6,36,10,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <StackPanel x:Name="EditorFieldsPanel" />
                        <StackPanel Visibility="Collapsed">
                        <Grid Style="{StaticResource FormRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="66" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="起始日期" Style="{StaticResource FieldLabelStyle}" />
                            <controls:FormattedDatePicker Grid.Column="1"
                                                          SelectedDate="{Binding EditableUser.StartDate, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource EditorDateStyle}" />
                        </Grid>

                        <Grid Style="{StaticResource FormRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="66" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="终止日期" Style="{StaticResource FieldLabelStyle}" />
                            <controls:FormattedDatePicker Grid.Column="1"
                                                          SelectedDate="{Binding EditableUser.EndDate, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource EditorDateStyle}" />
                        </Grid>

                        <Grid Style="{StaticResource FormRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="66" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding AccountFieldLabel}" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding EditableUser.AccountNo, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EditorTextBoxStyle}" />
                        </Grid>

                        <Grid Style="{StaticResource FormRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="66" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="姓名" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding EditableUser.AccountName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EditorTextBoxStyle}" />
                        </Grid>

                        <Grid Style="{StaticResource FormRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="66" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="身份证" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding EditableUser.IdNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EditorTextBoxStyle}" />
                        </Grid>

                        <Grid Style="{StaticResource FormRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="66" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="编号" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding EditableUser.UserCode, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EditorTextBoxStyle}" />
                        </Grid>

                        <Grid Style="{StaticResource FormRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="66" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="交易类型" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding EditableUser.TransactionType, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EditorTextBoxStyle}" />
                        </Grid>

                        <Grid Style="{StaticResource FormRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="66" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="币种" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding EditableUser.Currency, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EditorTextBoxStyle}" />
                        </Grid>

                        <Grid Style="{StaticResource FormRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="66" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="章内编码" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding EditableUser.ChapterCode, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EditorTextBoxStyle}" />
                        </Grid>

                        <Grid Style="{StaticResource FormRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="66" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="章内支行" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding EditableUser.ChapterBranch, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EditorTextBoxStyle}" />
                        </Grid>

                        <Grid Style="{StaticResource FormRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="78" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="是否打印章"
                                       Width="78"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding EditableUser.ShouldPrintSeal}"
                                      VerticalAlignment="Center" />
                        </Grid>

                        <Grid Style="{StaticResource FormRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="66" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="备注" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding EditableUser.Remark, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EditorTextBoxStyle}" />
                        </Grid>

                        <Grid Style="{StaticResource FormRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="66" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="期初余额" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding EditableUser.OpeningBalance, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                     Style="{StaticResource EditorTextBoxStyle}" />
                        </Grid>

                        <Grid Style="{StaticResource FormRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="自动计算利息"
                                       Width="92"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding EditableUser.AutoCalculateInterest}"
                                      VerticalAlignment="Center" />
                        </Grid>

                        </StackPanel>

                        <Border Width="150"
                                Height="100"
                                HorizontalAlignment="Left"
                                Margin="26,0,0,10"
                                BorderBrush="#9C9C9C"
                                BorderThickness="1"
                                Background="#EFEFEF">
                            <Image Source="{Binding EditableUser.SealImagePath}"
                                   Stretch="Uniform"
                                   Margin="3" />
                        </Border>

                        <StackPanel Orientation="Horizontal"
                                    Margin="12,0,0,10">
                            <Button Content="设置印章图片"
                                    Command="{Binding SetSealImageCommand}"
                                    Style="{StaticResource MiniButtonStyle}" />
                            <Button Content="复制路径"
                                    Command="{Binding CopySealPathCommand}"
                                    Style="{StaticResource MiniButtonStyle}" />
                            <Button Content="清除"
                                    Command="{Binding ClearSealCommand}"
                                    Style="{StaticResource MiniButtonStyle}" />
                        </StackPanel>

                        <Button Content="保存"
                                Width="80"
                                HorizontalAlignment="Center"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource MiniButtonStyle}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Background="White" />

            <DataGrid x:Name="UsersGrid"
                      Grid.Column="2"
                      ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      GridLinesVisibility="None"
                      Background="#E9E9E9"
                      RowBackground="White"
                      AlternatingRowBackground="#F7F7F7"
                      AlternationCount="2"
                      BorderThickness="0"
                      ColumnHeaderStyle="{StaticResource UserGridHeaderStyle}"
                      CellStyle="{StaticResource UserGridCellStyle}"
                      RowStyle="{StaticResource UserGridRowStyle}"
                      ColumnHeaderHeight="34"
                      RowHeight="30"
                      FontSize="14"
                      SnapsToDevicePixels="True"
                      PreviewMouseLeftButtonDown="UsersGrid_PreviewMouseLeftButtonDown"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto" />

            <StackPanel Grid.Column="3"
                        Margin="10,34,20,0"
                        VerticalAlignment="Top">
                <Button Content="新增" Command="{Binding NewCommand}" Style="{StaticResource SideButtonStyle}" />
                <Button Content="编辑" Command="{Binding EditCommand}" Style="{StaticResource SideButtonStyle}" />
                <Button Content="打印" Command="{Binding PrintCommand}" Style="{StaticResource SideButtonStyle}" />
                <Button Content="删除" Command="{Binding DeleteCommand}" Style="{StaticResource SideButtonStyle}" />
                <Button Content="复制" Command="{Binding CopyCommand}" Style="{StaticResource SideButtonStyle}" />
                <Button Content="保存" Command="{Binding SaveCommand}" Style="{StaticResource SideButtonStyle}" />
                <Button Content="导入xlsx" Command="{Binding ImportXlsxCommand}" Style="{StaticResource SideButtonStyle}" />
                <Button Content="导出xlsx" Command="{Binding ExportXlsxCommand}" Style="{StaticResource SideButtonStyle}" />
                <Button Content="自动生成流水" Command="{Binding AutoGenerateFlowCommand}" Style="{StaticResource SideButtonStyle}" />
                <Button Content="设置字段" Command="{Binding SetColumnsCommand}" Style="{StaticResource SideButtonStyle}" />
                <Button Content="设置利息" Command="{Binding SetInterestCommand}" Style="{StaticResource SideButtonStyle}" />
                <Button Content="合并流水" Command="{Binding MergeFlowCommand}" Style="{StaticResource SideButtonStyle}" />
                <Button Content="返回" Command="{Binding BackCommand}" Style="{StaticResource SideButtonStyle}" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
