<Window x:Class="SpeedEmulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SpeedEmulator.Controls"
        xmlns:models="clr-namespace:SpeedEmulator.Models"
        Title="{Binding WindowTitle, Mode=OneWay, FallbackValue=极速财务软件}"
        Width="900"
        Height="650"
        MinWidth="895"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrandTealBrush}">
    <Window.Resources>
        <DataTemplate x:Key="BankTileTemplate" DataType="{x:Type models:Bank}">
            <Button Style="{StaticResource BankTileButtonStyle}"
                    AutomationProperties.Name="{Binding Name}"
                    Command="{Binding DataContext.OpenBankCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    Width="110"
                    Height="100"
                    Margin="0,0,8,8">
                <Grid Width="102">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding Name}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="8,0" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding Type}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14" />
                </Grid>
            </Button>
        </DataTemplate>

        <Style x:Key="HomeTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="#F2F2F2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#E9ECEE"
                                    BorderBrush="#C6D0D3"
                                    BorderThickness="0,0,0,1" />
                            <TabPanel Grid.Row="0"
                                      Margin="10,0,0,0"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Panel.ZIndex="1" />
                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"
                                              Margin="0"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="18,7" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#E9ECEE" />
            <Setter Property="BorderBrush" Value="#C5CED2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="6,6,0,0"
                                Margin="0,0,4,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Panel.ZIndex" Value="2" />
                                <Setter Property="Background" Value="White" />
                                <Setter Property="BorderBrush" Value="#A9B6BB" />
                                <Setter TargetName="TabChrome" Property="BorderThickness" Value="0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFA" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TabChrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BrandTealBrush}"
                Height="194"
                ClipToBounds="True">
            <Grid>
                <Image Source="/Assets/jisu-theme-home-header-banner-year-blank.png"
                       Stretch="Fill"
                       IsHitTestVisible="False" />
                <Viewbox Stretch="Fill"
                         IsHitTestVisible="False"
                         ClipToBounds="True">
                    <Canvas Width="1774"
                            Height="388">
                        <TextBlock Text="{Binding CurrentYear, Mode=OneWay}"
                                   Canvas.Left="968"
                                   Canvas.Top="146"
                                   Foreground="Black"
                                   FontFamily="Arial"
                                   FontSize="72"
                                   FontWeight="Bold" />
                    </Canvas>
                </Viewbox>

                <Grid Margin="10,10,10,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="Transparent"
                            Padding="10"
                            Height="176">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="152" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Width="150"
                                  Height="150"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  ClipToBounds="True"
                                  SnapsToDevicePixels="True">
                                <Viewbox Stretch="Uniform"
                                         IsHitTestVisible="False">
                                    <Canvas Width="1024"
                                            Height="1536">
                                        <Image Source="/Assets/jisu-theme-logo-vertical-year-blank.png"
                                               Width="1024"
                                               Height="1536"
                                               Stretch="Fill" />
                                        <TextBlock Text="{Binding CurrentYear, Mode=OneWay}"
                                                   Canvas.Left="380"
                                                   Canvas.Top="614"
                                                   Foreground="Black"
                                                   FontFamily="Arial"
                                                   FontSize="56"
                                                   FontWeight="Bold" />
                                    </Canvas>
                                </Viewbox>
                            </Grid>

                            <ScrollViewer Grid.Column="1"
                                          Margin="18,8,0,8"
                                          Background="Transparent"
                                          Visibility="Collapsed"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="联系方式"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,10" />
                                    <TextBlock Text="{Binding ContactText, Mode=OneWay}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="16"
                                               LineHeight="24"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="Transparent"
                            Padding="24,18"
                            Height="176"
                            Visibility="Collapsed">
                        <ScrollViewer Background="Transparent"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding AnnouncementText, Mode=OneWay}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       LineHeight="25"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BrandTealBrush}"
                Padding="10,6,10,8">
            <TextBlock Foreground="#061F20"
                       VerticalAlignment="Center">
                <Run Text="ID: " />
                <Run Text="{Binding ExeId, Mode=OneWay}" />
            </TextBlock>
        </Border>

        <Grid Margin="10,0,10,0">
            <Border Background="#F2F2F2"
                    BorderBrush="#C8D4D6"
                    BorderThickness="1">
                <TabControl Margin="0"
                            Style="{StaticResource HomeTabControlStyle}"
                            SelectedIndex="0"
                            BorderThickness="0">
                    <TabItem Header="个人">
                        <ScrollViewer Padding="10,12,8,12" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding GeRenBanks}"
                                              ItemTemplate="{StaticResource BankTileTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="对公">
                        <ScrollViewer Padding="10,12,8,12" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding DuiGongBanks}"
                                              ItemTemplate="{StaticResource BankTileTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="地方">
                        <ScrollViewer Padding="10,12,8,12" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding DiFangBanks}"
                                              ItemTemplate="{StaticResource BankTileTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="凭条">
                        <ScrollViewer Padding="10,12,8,12" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ReceiptBanks}"
                                              ItemTemplate="{StaticResource BankTileTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </DockPanel>
</Window>
